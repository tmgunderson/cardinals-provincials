<!DOCTYPE HTML>

<html>

<head>
  <title>Document Archived</title>

<style>
#docA {
  border: 2px solid #000000;
  border-radius: 10px;
  width: auto;
  margin: 10px 1% 0px 1%;
  height: 500px;
  text-align: center;
  vertical-align: middle;
  font-size: 38px;
  font-weight: bold;
  font-family: Arial, Helvetica, sans-serif;
  box-sizing: border-box;
}
#docA span {
  display: block;
  margin-top: 200px;
  width: 70%;
  margin-left: auto;
  margin-right: auto;
}

</style>
</head>

<body>

<div id="docA"><span>Document has been Archived</span></div>

</body>

</html>